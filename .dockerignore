.venv
data/
docs/
tests/
.github/
.env
.env.*
!.env.example
**/__pycache__
*.py[cod]
.pytest_cache
.mypy_cache
.ruff_cache
.pre-commit-config.yaml
docker-compose.yml
compose.yml
Dockerfile
.dockerignore
README.md
CLAUDE.md
