# Copy to .env (chmod 600) next to compose.yml and set a real password:
#   openssl rand -hex 24
# Hex only: the password lands unescaped inside a connection URL.
POSTGRES_USER=shade
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shade

# Uvicorn worker count. The in-memory rate limiter counts per worker, so
# the effective per-IP limit is SHADE_API_RATE_LIMIT times this number.
WEB_CONCURRENCY=2
